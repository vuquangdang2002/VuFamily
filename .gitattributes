# ═══════════════════════════════════════════
# Git Attributes — VuFamily
# ═══════════════════════════════════════════

# Auto-detect text files and normalize line endings
* text=auto

# ── Source Code ──
*.js    text eol=lf
*.jsx   text eol=lf
*.mjs   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf

# ── Config & Shell ──
*.env         text eol=lf
*.env.*       text eol=lf
*.gitignore   text eol=lf
*.gitattributes text eol=lf
.vercelignore text eol=lf
Dockerfile    text eol=lf
Makefile      text eol=lf
*.sh          text eol=lf

# ── Binary files (no diff, no merge) ──
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.db    binary

# ── Lock files (no diff noise) ──
package-lock.json -diff
yarn.lock         -diff

# ── Linguist overrides (GitHub language stats) ──
client/src/utils/lunar.js  linguist-vendored
client/src/utils/lunarCalendar.js linguist-vendored
