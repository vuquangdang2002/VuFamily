                                    <div className="w-14 h-14 rounded-2xl bg-purple-500/10 border border-purple-500/20 text-purple-400 flex items-center justify-center mb-6 shadow-inner">
                                        <Newspaper size={28} />
                                    </div>
                                    <h3 className="text-xl font-bold text-white mb-3 group-hover:text-purple-400 transition-colors">Bảng tin gắn kết tình thân</h3>
                                    <p className="text-zinc-400 leading-relaxed">
