{
  "name": "vu-family-genealogy",
  "version": "2.0.1",
  "description": "Gia Phả - Ứng dụng web Gia phả dòng họ Vũ",
  "main": "backend/src/index.ts",
  "scripts": {
    "dev:server": "wrangler dev",
    "client": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run client\"",
    "build": "cd frontend && npm install && npm run build",
    "build:client": "cd frontend && npm install && npm run build",
    "install:all": "npm install && cd frontend && npm install",
    "db:push": "wrangler d1 execute vufamily-db --file=database/seed_d1.sql --remote",
    "deploy": "npm run build && wrangler deploy"
  },
  "keywords": [
    "genealogy",
    "family-tree",
    "gia-pha"
  ],
  "author": "Vũ Family",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.6.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.30",
    "resend": "^6.17.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260718.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "nodemon": "^3.0.2",
    "typescript": "^7.0.2",
    "wrangler": "^4.112.0"
  }
}
