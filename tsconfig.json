{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "lib": ["es2022"],
    "types": [
      "@cloudflare/workers-types",
      "node"
    ],
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": true
  },
  "include": ["api/src/**/*.ts"],
  "exclude": ["node_modules", "client"]
}
