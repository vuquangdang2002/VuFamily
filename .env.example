# ==========================================
# ⚙️ GIA PHẢ - CENTRAL CONFIGURATION (.env)
# ==========================================

# 1. Tên miền & Đường dẫn (DOMAIN & URL)
VITE_APP_DOMAIN=family.dangvq.online
VITE_APP_URL=https://family.dangvq.online
VITE_API_BASE_URL=https://family.dangvq.online/api

# 2. Cơ sở dữ liệu (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...your-service-key

# 3. Cơ sở dữ liệu Backup (Failover)
SUPABASE_BACKUP_URL=https://your-backup-project.supabase.co
SUPABASE_BACKUP_KEY=eyJhbGci...your-backup-service-key

# 4. Gửi Email (Resend)
RESEND_API_KEY=re_your_api_key
ADMIN_EMAIL=your@email.com

# 5. Cấu hình Backend Server (Express dev)
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000
DB_PATH=./database/family.db
